{
  "name": "single-version database avoids unnecessary expand and contract",
  "contract": "database-compatibility",
  "input": {
    "concurrent_application_versions": false,
    "external_clients": false
  },
  "assertions": [
    {"path": "observed.migration_strategy", "operator": "equals", "value": "direct"},
    {"path": "observed.expand_and_contract", "operator": "is_false"}
  ]
}
